{
  "name": "mnemon",
  "version": "1.3.0",
  "description": "WebAssembly linear memory snapshot tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mnemon": "dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test 'dist/__tests__/**/*.test.js'",
    "start": "node dist/index.js",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "npm run build"
  },
  "author": "Valerio Cancemi",
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
